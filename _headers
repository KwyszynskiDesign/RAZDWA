# Cache-Control headers
# GitHub Pages does not support this file natively.
# This file works on Netlify and Cloudflare Pages.
# For GitHub Pages, caching is controlled by meta tags in index.html and the service worker.

/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

/*.json
  Cache-Control: no-cache, no-store, must-revalidate
