{
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.5.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "prettier": "^3.8.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.0"
  },
  "name": "razdwa",
