# RAZDWA — przykładowa konfiguracja środowiskowa
#
# Skopiuj ten plik jako .env i uzupełnij wartości.
# Plik .env NIE jest i nie może być commitowany do repozytorium.
#
# Endpoint Google Apps Script jest konfiguracją BUILD-TIME, nie runtime.
# Flow: GitHub Secret GOOGLE_APPS_SCRIPT_URL -> esbuild define (scripts/build.mjs)
#       -> stała CURRENT_APPS_SCRIPT_URL -> zapieczona w bundlu docs/assets/app.js
#
# Lokalnie: ustaw GOOGLE_APPS_SCRIPT_URL w .env, build odczyta go automatycznie.
# Produkcja (CI): wartość pochodzi z GitHub Secret (.github/workflows/deploy.yml).
#
# UWAGA: panel Ustawień NIE ustawia tego URL. Runtime override w localStorage
# (razdwa_order_export_config) istnieje w kodzie, jest walidowany
# (https://script.google.com/.../exec), ale nie jest podłączony do UI.

# URL Google Apps Script Web App dla danej drukarni.
# Pobierz go z: Apps Script → Deploy → Web App → URL kończący się na /exec
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Profil środowiskowy: dev | staging | client
# dev     — lokalne środowisko deweloperskie; brak GAS_URL daje warning, nie blokuje
# staging — środowisko testowe; brak GAS_URL blokuje send
# client  — produkcja; brak GAS_URL blokuje send + pokazuje baner błędu
RAZDWA_ENV=dev

# Identyfikator drukarni (slug), np. raz-dwa. Wyświetlany w komunikatach błędów konfiguracji.
RAZDWA_CLIENT_ID=raz-dwa
